# Database Connection
# This is the main database URL used by Prisma
# Format: postgresql://user:password@host:port/database?options
DATABASE_URL="postgresql://user:password@localhost:5432/podnex?sslmode=prefer"

# For production, use a managed database service like:
# - Neon: postgresql://user:password@ep-xxx.region.aws.neon.tech/database?sslmode=require
# - Supabase: postgresql://user:password@db.xxx.supabase.co:5432/postgres
# - Railway: postgresql://user:password@containers-us-west-xxx.railway.app:5432/railway
