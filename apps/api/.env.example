# Frontend & Auth
FRONTEND_URL="http://localhost:3000"
BETTER_AUTH_URL="http://localhost:3001"
BETTER_AUTH_SECRET="your-secret-here" # Generate with: openssl rand -base64 32

# AI Services
OPENAI_API_KEY="sk-proj-your-openai-api-key-here"
ELEVENLABS_API_KEY="sk_your-elevenlabs-api-key-here"
UNREAL_SPEECH_API_KEY="your-unreal-speech-api-key-here"

# TTS Configuration
TTS_PROVIDER="unreal" # Options: 'unreal', 'elevenlabs'

# AWS / Storage (S3 or R2)
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_REGION="us-east-1"
S3_BUCKET_NAME="your-bucket-name"

# Optional: For Cloudflare R2 or other S3-compatible services
# S3_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
